# Only if hosting publicly, using HTTPS and a custom domain. Otherwise, you can leave this commented out.
# NEXTAUTH_URL=https://sub.domain.tld/api/v1/auth

# Secret for Next Auth (can be any string, but should be kept secret)
NEXTAUTH_SECRET=password

# Secret for Meili Search (can be any string, but should be kept secret)
MEILI_MASTER_KEY=meilipassword

# Secret for Postgres (can be any string, but should be kept secret)
POSTGRES_PASSWORD=dbpassword